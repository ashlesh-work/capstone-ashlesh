# ──────────────────────────────────────────────────────────────────────────
# Access508 — environment configuration
# Copy to `.env` and fill in. `.env` is git-ignored and NEVER ships to the browser.
# All provider calls happen server-side; the front end only talks to this server.
# ──────────────────────────────────────────────────────────────────────────

# --- Server ---
PORT=8787
# Comma-separated origins allowed to call the API (the Vite dev server by default).
CORS_ORIGINS=http://localhost:5173

# --- Provider keys (server-side only) ---
OPENAI_API_KEY=sk-...                 # used for STT (Whisper), LLM, and (optionally) embeddings
ELEVENLABS_API_KEY=...                # used for streaming TTS

# --- Provider selection (swap providers without code changes) ---
STT_PROVIDER=openai                   # openai | openai-realtime
LLM_PROVIDER=openai
TTS_PROVIDER=elevenlabs

# --- Model / voice config ---
OPENAI_LLM_MODEL=gpt-4o-mini
OPENAI_STT_MODEL=whisper-1
OPENAI_EMBED_MODEL=text-embedding-3-small
ELEVENLABS_VOICE_ID=                  # a premium ElevenLabs voice id
ELEVENLABS_TTS_MODEL=eleven_turbo_v2_5

# --- Retrieval ---
# lexical = offline TF-IDF (default; zero network, great for local POC + CI).
# embedding = OpenAI embeddings (production-quality; requires OPENAI_API_KEY).
RETRIEVER=lexical
# Minimum similarity (0-1) to treat retrieval as a confident, citable match.
# Below this, the bot falls back to clearly-labeled general guidance.
RETRIEVAL_THRESHOLD=0.12

# ── Capstone: tracing, memory, tools, evaluation ──────────────────────────

# Where JSONL traces + LLM-as-judge runs are persisted (git-ignored).
# Relative paths resolve against the server working directory (server/).
DATA_DIR=data

# Session memory retention rules (Phase 6):
# idle minutes before a session's short-term memory is reset…
SESSION_TTL_MIN=60
# …and how many conversation exchanges are kept as context.
MEMORY_TURNS=4

# Loop-prevention cap on tool routing retries per turn (Phase 5 safeguard).
TOOL_MAX_ITERATIONS=2

# LLM-as-a-judge (Phase 9). Uses OPENAI_API_KEY; judge model can differ
# from the production model to avoid self-grading bias.
JUDGE_MODEL=gpt-4o-mini

# Production prompt strategy (v1=minimal, v2=grounded+cited [default], v3=strict).
# v2 selected via judged comparison — see docs/evaluation-report.md.
PROMPT_VARIANT=v2

# Optional shared secret for the trainer console (/eval) and /api/traces*.
# Leave empty for open local demos; set any string to require it
# (the /eval page has a token field that sends it as x-eval-token).
EVAL_TOKEN=
