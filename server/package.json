{
  "name": "@access508/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Fastify proxy: holds API keys server-side, exposes /api/chat (RAG+citations), /api/stt, /api/tts. Provider adapters are swappable via env.",
  "scripts": {
    "dev": "tsx watch --env-file=../.env src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@access508/core": "*",
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^9.1.3",
    "fastify": "^5.8.5",
    "undici": "^6.19.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.12",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4"
  }
}
